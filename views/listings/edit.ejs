<% layout("/layouts/boilerplate") %>
<body>
<div class="row">
    <div class="col-8 offset-2">
    <br>
    <h3>Edit Your Listing</h3>
    <form method="POST" action="/listing/<%= listing._id %>?_method=PUT" novalidate class="needs-validation" enctype="multipart/form-data"> <!--Put is used to update an existing data-->
        <div class="mb-3">
            <lable for="title" class="form-label">Title</lable>
            <input name="listing[title]" value="<%= listing.title %>" type="text" class="form-control" required>
            <div class="invalid-feedback">Enter Title</div>
        </div>
        
        <div class="mb-3">
            <lable for="description" class="form-label">Description</lable>
            <textarea name="listing[description]" type="text" class="form-control" required><%= listing.description%></textarea>
            <div class="invalid-feedback">Enter a description</div>
        </div>
        
        <div class="mb-3">
            <p>Original Listing Image</p>
            <img src="<%= newImageURL %>">  <!--Showing the original image during editing-->
        </div>
        <div class="mb-3">
            <lable for="image" class="form-label">Upload New Image</lable>
            <input name="listing[image]" value="<%= listing.image %>" type="file" class="form-control" required>
            <div class="invalid-feedback">Provide an Image</div>
        </div>
        <div class="row">
            <div class="mb-3 col-md-4">
                <lable for="price" class="form-label">Price</lable>
                <input name="listing[price]" value="<%= listing.price %>" type="Number" class="form-control" required>
                <div class="invalid-feedback">Enter a price</div>
            </div>
            
            <div class="mb-3 col-md-8">
                <lable for="country" class="form-label">Country</lable>
                <input name="listing[country]" value="<%= listing.country %>" type="text" class="form-control" required>
                <div class="invalid-feedback">Provide a country name</div>
            </div>
        </div>
        
        <div class="mb-3">
            <label for="location" class="form-label">Location</label>
            <input name="listing[location]" value="<%= listing.location %>" type="text" class="form-control" required>
            <div class="invalid-feedback">Provide a location</div>
        </div>
        <br>
        <button class="btn btn-dark edit-btn">Edit</button>
        <br><br>
    </form>
    </div>
</div>
</body>
